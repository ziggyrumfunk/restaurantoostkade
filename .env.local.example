# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Service role key (server only, never expose to client)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Site
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Notifications — Resend (https://resend.com)
# Get your API key from https://resend.com/api-keys
RESEND_API_KEY=re_your_key_here
NOTIFICATION_EMAIL=info@restaurantoostkade.nl
# Until you verify your domain with Resend, leave this on onboarding@resend.dev.
# Once verified, switch to "Restaurant Oostkade <info@restaurantoostkade.nl>".
RESEND_FROM_EMAIL=Oostkade Website <onboarding@resend.dev>
